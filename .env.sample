# Wallet used to sign subscribe/activate txs in the examples.
# Provide ONE of: a base58 secret key, or a path to a Solana CLI keypair JSON file.
SECRET_KEY=
KEYPAIR_PATH=

# Optional custom RPC endpoints (fall back to public Solana RPC if blank).
RPC_URL_devnet=
RPC_URL_mainnet=

# Save from the signup flow.
JWT_devnet=
TX_SIG_devnet=
API_KEY_devnet=

JWT_mainnet=
TX_SIG_mainnet=
API_KEY_mainnet=
